# Local development placeholders (no secrets)
LOCAL_SUPABASE_URL=http://localhost:54321
LOCAL_SUPABASE_ANON_KEY=local-dev-key

# Supabase Service Role Key (required for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
LOCAL_SUPABASE_SERVICE_ROLE_KEY=your-local-supabase-service-role-key

# Admin JWT Secret (required for admin authentication)
ADMIN_JWT_SECRET=your-secure-admin-jwt-secret-key-change-in-production

# Frontend (pick the ones your app uses)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=local-dev-key
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=local-dev-key
VITE_API_URL=http://localhost:3000

# Storage
SUPABASE_BUCKET=exercise-videos

# Server
PORT=3000

# Temporary dev bypass switch (remove before production)
DISABLE_ADMIN_GUARD=false
# set to true to disable admin guard and bypass auth checks (for local dev only)
# set to false otherwise (dont push to prod as true)

# SMTP Configuration (No API)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# --- Supabase Edge Function secrets (set in Supabase Dashboard → Edge Functions → Secrets) ---
#
# Password reset (forgot-password + reset-password) and admin approve/deny (admin-approval) all use Resend.
# RESEND_API_KEY                       = required for any email to send
# FRONTEND_RESET_PASSWORD_URL         = mobile app reset link base (?token= appended)
# FRONTEND_RESET_PASSWORD_WEB_URL     = optional; web admin reset base if not using browser origin
# WEB_RESET_ALLOWED_ORIGINS           = optional; comma-separated https origins for prod web reset links
# RESET_FROM_EMAIL                    = optional; used for password reset + approve/deny if others unset
# RESEND_FROM_EMAIL                   = optional; preferred for approve/deny (same format as below)
# FROM_EMAIL                          = optional; third fallback for “from” address
#
# “From” format example:   Floora HEP <noreply@clinicdomain.com>
#
# --- Why only my inbox gets mail during testing ---
# Resend’s built-in test address (onboarding@resend.dev) only delivers to the Resend account owner’s email.
# That is normal until you add and verify the clinic’s real domain in Resend (see checklist below).
#
# --- After the owner verifies their real domain (do in this order) ---
# 1) In Resend (resend.com): add the clinic’s domain → add the DNS records Resend shows → wait until status is Verified.
# 2) In Resend: create or reuse an API key → put the same key in Supabase secret RESEND_API_KEY (if it changed).
# 3) In Supabase secrets: set RESET_FROM_EMAIL and RESEND_FROM_EMAIL (and optionally FROM_EMAIL) to the SAME
#    branded address on the verified domain, e.g. Floora HEP <noreply@clinicdomain.com>.
#    (Code tries these in order; one value in all three is fine.)
# 4) Redeploy Edge Functions so the latest code runs:  supabase functions deploy forgot-password reset-password admin-approval
# 5) Send a test: forgot password + approve a test user — both should show “from” the new address and arrive at any real recipient.
# 6) If you use the Node backend SMTP path (nodemailer / approve via Express): set FROM_EMAIL + SMTP_* to the same domain
#    or point SMTP at Resend’s SMTP docs so “from” matches.
# 7) Optional: Supabase Auth emails (if you ever use built-in auth email again): Dashboard → Auth → SMTP with same provider/domain.
