# Local development placeholders (no secrets)
LOCAL_SUPABASE_URL=http://localhost:54321
LOCAL_SUPABASE_ANON_KEY=local-dev-key

# Supabase Service Role Key (required for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
LOCAL_SUPABASE_SERVICE_ROLE_KEY=your-local-supabase-service-role-key

# Admin JWT Secret (required for admin authentication)
ADMIN_JWT_SECRET=your-secure-admin-jwt-secret-key-change-in-production

# Frontend (pick the ones your app uses)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=local-dev-key
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=local-dev-key
VITE_API_URL=http://localhost:3000

# Storage
SUPABASE_BUCKET=exercise-videos

# Server
PORT=3000

# Temporary dev bypass switch (remove before production)
DISABLE_ADMIN_GUARD=false
# set to true to disable admin guard and bypass auth checks (for local dev only)
# set to false otherwise (dont push to prod as true)

# SMTP Configuration (No API)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
